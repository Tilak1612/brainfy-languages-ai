# --- AI tutor (text conversation) ---
# Anthropic API key. Enables the live Claude tutor on the Voice screen.
# Used only server-side (/api/chat). Without it, the app uses a scripted tutor.
ANTHROPIC_API_KEY=

# --- Voice (speech-to-text + text-to-speech, NVIDIA Riva) ---
# NGC / build.nvidia.com API key with the "Cloud Functions" scope.
# Enables mic input (ASR) and Maya's spoken replies (TTS) via /api/stt + /api/tts.
# Voice runs on Vercel (or `vercel dev`), not plain `npm run dev`.
NVIDIA_API_KEY=

# Optional overrides:
# NVIDIA_TTS_VOICE=            # a Magpie voice name (see `talk.py --list-voices`)
# NVIDIA_ASR_PATTERN=parakeet|canary|nemotron-asr
# NVIDIA_TTS_PATTERN=magpie|tts
# NVIDIA_ASR_LANG=en-US

# --- Accounts + progress sync (Supabase) ---
# Project: brainfy-languages-prod (ref qwpxcwnnobalpglbwzip, ca-central-1),
# org "Brainfy". Dedicated to this app so auth.users is not shared with any
# other product in the portfolio.
#
# Set BOTH to turn on real accounts. When they are absent the app runs as the
# self-contained demo: no sign-in, seeded design numbers, progress in
# localStorage, and the /api/* endpoints stay open.
#
# When they ARE set:
#   - users must sign in; a new account starts at zero XP/streak
#   - progress, SRS cards and custom tutors persist to Postgres (RLS: owner-only)
#   - /api/chat, /api/tts and /api/stt require the caller's access token and
#     enforce a per-user hourly quota
#
# These are read at BUILD time by Vite, so changing them needs a redeploy.
# The anon/publishable key is public by design and ships in the browser bundle —
# row-level security is what protects the data, not this key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional:
# CHAT_HOURLY_LIMIT=40         # Pro: /api/chat calls per hour (default 40)
# CHAT_FREE_DAILY_LIMIT=10     # Free: /api/chat calls per day (default 10)

# --- Billing (Stripe) ---
# Without these the Upgrade button reports "billing not configured" and every
# signed-in user stays on the free tier. Nothing else breaks.
#
# Secret key: sk_test_... in sandbox, sk_live_... in production.
STRIPE_SECRET_KEY=
# From `stripe listen` locally, or Dashboard > Developers > Webhooks.
# The webhook is the ONLY thing that can grant Pro, so this must be set.
STRIPE_WEBHOOK_SECRET=
# Price IDs are env-scoped on purpose: TEST price IDs are invalid against a LIVE
# secret key, so going live is an env change, not a code change.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
# Optional:
# STRIPE_TRIAL_DAYS=14         # set here, not on the Stripe price
# PUBLIC_SITE_URL=https://brainfy-languages-ai.vercel.app   # Stripe return URLs

# --- Service role (server-only, NEVER expose to the browser) ---
# Used only by the Stripe webhook to write lang_subscriptions, which RLS forbids
# the user themselves from writing. Note there is no VITE_ prefix — a VITE_ name
# would be inlined into the client bundle and hand every visitor admin access.
SUPABASE_SERVICE_ROLE_KEY=
