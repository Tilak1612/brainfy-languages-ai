# --- AI tutor (text conversation) ---
# Anthropic API key. Enables the live Claude tutor on the Voice screen.
# Used only server-side (/api/chat). Without it, the app uses a scripted tutor.
ANTHROPIC_API_KEY=

# --- Voice (speech-to-text + text-to-speech, NVIDIA Riva) ---
# NGC / build.nvidia.com API key with the "Cloud Functions" scope.
# Enables mic input (ASR) and Maya's spoken replies (TTS) via /api/stt + /api/tts.
# Voice runs on Vercel (or `vercel dev`), not plain `npm run dev`.
NVIDIA_API_KEY=

# Optional overrides:
# NVIDIA_TTS_VOICE=            # a Magpie voice name (see `talk.py --list-voices`)
# NVIDIA_ASR_PATTERN=parakeet|canary|nemotron-asr
# NVIDIA_TTS_PATTERN=magpie|tts
# NVIDIA_ASR_LANG=en-US

# --- Accounts + progress sync (Supabase) ---
# Set BOTH to turn on real accounts. When they are absent the app runs as the
# self-contained demo: no sign-in, seeded design numbers, progress in
# localStorage, and the /api/* endpoints stay open.
#
# When they ARE set:
#   - users must sign in; a new account starts at zero XP/streak
#   - progress, SRS cards and custom tutors persist to Postgres (RLS: owner-only)
#   - /api/chat, /api/tts and /api/stt require the caller's access token and
#     enforce a per-user hourly quota
#
# These are read at BUILD time by Vite, so changing them needs a redeploy.
# The anon/publishable key is public by design and ships in the browser bundle —
# row-level security is what protects the data, not this key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional:
# CHAT_HOURLY_LIMIT=120        # per-user /api/chat calls per hour (default 120)
